<UserControl x:Class="TareFlow.Center.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Ayarlar" FontSize="26" FontFamily="{StaticResource GoogleSansBold}" Margin="0,0,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                
                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="14"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="22">
                    <StackPanel>
                        <TextBlock Text="Kantar &amp; Yazıcı" FontSize="16" FontFamily="{StaticResource GoogleSansBold}" Margin="0,0,0,12"/>
                        <TextBlock Text="Kantar Köprüsü IP (Agent)" Style="{StaticResource DialogLabel}"/>
                        <TextBox Text="{Binding AgentHost}" Margin="0,0,0,12"/>
                        <TextBlock Text="Port" Style="{StaticResource DialogLabel}"/>
                        <TextBox Text="{Binding AgentPort}" Margin="0,0,0,12"/>
                        <TextBlock Text="Termal Yazıcı (80mm USB)" Style="{StaticResource DialogLabel}"/>
                        <ComboBox ItemsSource="{Binding Printers}" SelectedItem="{Binding PrinterName}"/>
                    </StackPanel>
                </Border>

                
                <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="14"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="22">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IP Kameralar" FontSize="16"
                                       FontFamily="{StaticResource GoogleSansBold}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Ekle" Command="{Binding AddCameraCommand}"
                                    Width="70" Height="32" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="Sil" Command="{Binding RemoveCameraCommand}"
                                    Width="60" Height="32" Style="{StaticResource DangerButton}"/>
                        </Grid>
                        <TextBlock Text="Birden fazla kamera tanımlayabilirsiniz. Tartım ekranında aralarında geçiş yapılır."
                                   Style="{StaticResource DialogLabel}" TextWrapping="Wrap"/>
                        <DataGrid ItemsSource="{Binding Cameras}" SelectedItem="{Binding SelectedCamera}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" BorderThickness="0"
                                  Background="Transparent" HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal" RowHeight="34" FontSize="13" MinHeight="160">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="İsim" Binding="{Binding Name}" Width="90"/>
                                <DataGridTextColumn Header="RTSP Adresi" Binding="{Binding RtspUrl}" Width="*"/>
                                <DataGridTextColumn Header="Kullanıcı" Binding="{Binding User}" Width="90"/>
                                <DataGridTextColumn Header="Şifre" Binding="{Binding Password}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                <Button Content="Kaydet ve Uygula" Command="{Binding SaveCommand}" Width="180" Style="{StaticResource PrimaryButton}"/>
                <Button Content="CSV İçe Aktar" Command="{Binding ImportCsvCommand}" Width="160" Margin="12,0,0,0"
                        Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
