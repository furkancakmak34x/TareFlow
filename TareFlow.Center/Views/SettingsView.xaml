<UserControl x:Class="TareFlow.Center.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TareFlow.Center.Views">
    <UserControl.Resources>
        <views:NotNullToBoolConverter x:Key="NotNull"/>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ayarlar" FontSize="26" FontFamily="{StaticResource GoogleSansBold}" Margin="0,0,0,18"/>

        <!-- İçerik: sol sabit kart + sağ genişleyen kamera kartı -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Kantar & Yazıcı -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="14"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="22" VerticalAlignment="Center" Height="455">
                <StackPanel>
                    <TextBlock Text="Kantar &amp; Yazıcı" FontSize="16" FontFamily="{StaticResource GoogleSansBold}" Margin="0,0,0,14"/>
                    <TextBlock Text="Kantar IP" Style="{StaticResource DialogLabel}"/>
                    <TextBox Text="{Binding AgentHost}" Margin="0,0,0,12"/>
                    <TextBlock Text="Port" Style="{StaticResource DialogLabel}"/>
                    <TextBox Text="{Binding AgentPort}" Margin="0,0,0,12"/>
                    <TextBlock Text="Fiş Yazıcısı" Style="{StaticResource DialogLabel}"/>
                    <ComboBox ItemsSource="{Binding Printers}" SelectedItem="{Binding PrinterName}" Margin="0,0,0,12"/>
                    <TextBlock Text="Yazıcı Türü" Style="{StaticResource DialogLabel}"/>
                    <ComboBox SelectedIndex="{Binding PrinterKindIndex}">
                        <ComboBoxItem Content="80mm Termal (ESC/POS)"/>
                        <ComboBoxItem Content="Nokta Vuruşlu — USB (ESC/P)"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- IP Kameralar (genişler) -->
            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="14"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="22">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="IP Kameralar" FontSize="16"
                                   FontFamily="{StaticResource GoogleSansBold}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Ekle" Command="{Binding AddCameraCommand}"
                                Height="34" Width="90" Padding="16,0" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Sil" Command="{Binding RemoveCameraCommand}"
                                Height="34" Width="90" Padding="16,0" Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                    </Grid>
                    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,14" TextWrapping="Wrap"
                               Text="Birden fazla kamera tanımlayabilirsiniz. Tartım ekranında aralarında geçiş yapılır."
                               Style="{StaticResource DialogLabel}"/>

                    <!-- Liste + düzenleme -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Kamera listesi -->
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="5">
                            <ListBox ItemsSource="{Binding Cameras}" SelectedItem="{Binding SelectedCamera}"
                                     Background="Transparent" BorderThickness="0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="12,9">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE412;" FontFamily="{DynamicResource GoogleMaterialSymbols}"
                                                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding Name}" FontFamily="{StaticResource GoogleSansMedium}"
                                                                       FontSize="14" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                            <Setter Property="TextElement.Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>

                        <!-- Seçili kamera düzenleme -->
                        <StackPanel Grid.Column="2" IsEnabled="{Binding SelectedCamera, Converter={StaticResource NotNull}}">
                            <TextBlock Text="Kamera Adı" Style="{StaticResource DialogLabel}"/>
                            <TextBox Text="{Binding SelectedCamera.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="RTSP Adresi" Style="{StaticResource DialogLabel}" VerticalAlignment="Bottom"/>
                            </Grid>
                            <TextBox Text="{Binding SelectedCamera.RtspUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Kullanıcı Adı" Style="{StaticResource DialogLabel}"/>
                                    <TextBox Text="{Binding SelectedCamera.User, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Şifre" Style="{StaticResource DialogLabel}"/>
                                    <TextBox Text="{Binding SelectedCamera.Password, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                                    <CheckBox Content="PTZ"
                                              IsChecked="{Binding SelectedCamera.HasPtz}" Margin="0,0,0,8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="ONVIF Port" Style="{StaticResource DialogLabel}"/>
                                    <TextBox Text="{Binding SelectedCamera.OnvifPort}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Yerel SDK protokolü ayarları -->
                            <Grid Margin="0,12,0,0" IsEnabled="{Binding SelectedCamera.IsSdkSettingsEnabled}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="2"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Alt aksiyonlar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,22,0,0">
            <Button Content="Kaydet" Command="{Binding SaveCommand}" Width="180" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
