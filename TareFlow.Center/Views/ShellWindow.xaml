<Window x:Class="TareFlow.Center.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TareFlow.Center.Views"
        Title="TareFlow — Uzaktan Kantar" Height="800" Width="1280"
        WindowStyle="None" WindowState="Maximized" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Window.Resources>
        <views:BoolToConnectionBrushConverter x:Key="ConnBrush"/>
        <views:BoolToConnectionTextConverter x:Key="ConnText"/>
        <views:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <views:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>

        
        <Style x:Key="HomeTileStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileBorder" Background="{TemplateBinding Background}" CornerRadius="20"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="TileScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Grid Margin="26">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{TemplateBinding Tag}" FontFamily="{DynamicResource GoogleMaterialSymbols}"
                                           FontSize="58" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.95"/>
                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="{TemplateBinding Content}" FontFamily="{StaticResource GoogleSansBold}"
                                               FontSize="22" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding (ToolTipService.ToolTip), RelativeSource={RelativeSource TemplatedParent}}"
                                               FontFamily="{StaticResource GoogleSans}" FontSize="13" Opacity="0.8" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="TileScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.15"/>
                                    <DoubleAnimation Storyboard.TargetName="TileScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.15"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="TileScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15"/>
                                    <DoubleAnimation Storyboard.TargetName="TileScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="SmallActionStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="14" Padding="16,12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}" FontFamily="{DynamicResource GoogleMaterialSymbols}"
                                           FontSize="22" VerticalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Content}" FontFamily="{StaticResource GoogleSansMedium}"
                                           FontSize="15" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="22,8">
                            <TextBlock Text="&#xE5C4;" FontFamily="{DynamicResource GoogleMaterialSymbols}" FontSize="24"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        
        <Grid Visibility="{Binding IsHome, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="50,40,50,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="56" Height="56" CornerRadius="16" Background="{DynamicResource PrimaryBrush}" Margin="0,0,16,0">
                        <TextBlock Text="&#xE558;" FontFamily="{StaticResource GoogleMaterialSymbols}" FontSize="32"
                                   Foreground="{DynamicResource OnPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bayat Köyü Kantarı" FontFamily="{StaticResource GoogleSansBold}" FontSize="36"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtDate" FontFamily="{StaticResource GoogleSansMedium}" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TxtTime" FontFamily="{StaticResource GoogleSansBold}" FontSize="30"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Row 1: Dashboard Tiles (1 - 2 - 2 Column-based Grid Layout) -->
            <Grid Grid.Row="1" Margin="42,10,42,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 0 (Tall Tile spanning both rows): Tartım -->
                <Button Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                        Style="{StaticResource HomeTileStyle}" Background="{DynamicResource PrimaryBrush}"
                        Content="Tartım" Tag="&#xE3B0;" ToolTip="Araç tartım işlemleri."
                        Command="{Binding ShowStationCommand}"/>

                <!-- Column 1 (Middle Column): Kayıtlar (Top) & Tahsilat Ekranı (Bottom) -->
                <Button Grid.Row="0" Grid.Column="1"
                        Style="{StaticResource HomeTileStyle}" Background="{DynamicResource WarningBrush}"
                        Content="Kayıtlar" Tag="&#xE889;" ToolTip="Geçmiş tartım kayıtları."
                        Command="{Binding ShowRecordsCommand}"/>

                <Button Grid.Row="1" Grid.Column="1"
                        Style="{StaticResource HomeTileStyle}" Content="Tahsilat Ekranı" Tag="&#xE227;"
                        ToolTip="Müşteri bazlı bekleyen kantar ücretleri." Command="{Binding ShowReceivableCommand}">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="#EC4899" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <!-- Column 2 (Right Column): Ayarlar (Top) & Sistemi Kapat (Bottom) -->
                <Button Grid.Row="0" Grid.Column="2"
                        Style="{StaticResource HomeTileStyle}" Background="{DynamicResource SecondaryBrush}"
                        Content="Ayarlar" Tag="&#xE8B8;" ToolTip="Kantar, kamera ve yazıcı ayarları."
                        Command="{Binding ShowSettingsCommand}"/>

                <Button Grid.Row="1" Grid.Column="2"
                        Style="{StaticResource HomeTileStyle}" Background="{DynamicResource ErrorBrush}"
                        Content="Kapat" Tag="&#xE8AC;" ToolTip="Uygulamayı güvenli bir şekilde kapatır."
                        Click="BtnExit_Click"/>
            </Grid>

            <!-- Row 2: Scale Status -->
            <Grid Grid.Row="2" Margin="50,10,50,30">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="11" Height="11" VerticalAlignment="Center"
                             Fill="{Binding Scale.IsConnected, Converter={StaticResource ConnBrush}}"/>
                    <TextBlock Margin="8,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center">
                        <Run Text="Kantar: "/>
                        <Run Text="{Binding Scale.IsConnected, Converter={StaticResource ConnText}, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="14,0,0,0" Foreground="{DynamicResource SecondaryBrush}" FontFamily="{StaticResource GoogleSansBold}" VerticalAlignment="Center">
                        <Run Text="{Binding Scale.CurrentWeight, Mode=OneWay}"/><Run Text=" kg"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>

        
        <Grid Visibility="{Binding IsHome, Converter={StaticResource InvBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource BackButtonStyle}" Margin="12,10" Command="{Binding GoHomeCommand}"/>
                    <TextBlock Grid.Column="1" Text="{Binding PageTitle}" FontFamily="{StaticResource GoogleSansBold}"
                               FontSize="18" VerticalAlignment="Center" Margin="6,0,0,0"/>

                    
                    <Border Grid.Column="3" Margin="0,0,18,0" Padding="14,7" CornerRadius="20"
                            Background="{DynamicResource SurfaceVariantBrush}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                     Fill="{Binding Scale.IsConnected, Converter={StaticResource ConnBrush}}"/>
                            <TextBlock Margin="8,0,0,0" Foreground="{DynamicResource SecondaryBrush}"
                                       FontFamily="{StaticResource GoogleSansBold}" VerticalAlignment="Center">
                                <Run Text="{Binding Scale.CurrentWeight, Mode=OneWay}"/><Run Text=" kg"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>
        </Grid>
    </Grid>
</Window>
