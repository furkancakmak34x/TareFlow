<UserControl x:Class="TareFlow.Center.Views.SecondWeighView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TareFlow.Center.Views">
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Bekleyen araçlar -->
        <DockPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock DockPanel.Dock="Top" Text="Bekleyen Araçlar" FontSize="16"
                       FontFamily="{StaticResource GoogleSansBold}" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="14"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6">
                <ListBox ItemsSource="{Binding Pending}" SelectedItem="{Binding Selected}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="10" Padding="12,8">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="TextElement.Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Plate}" FontFamily="{StaticResource GoogleSansBold}" FontSize="15"/>
                                <TextBlock Text="{Binding Date}" Opacity="0.7" FontSize="11"/>
                                <TextBlock FontSize="11" Opacity="0.8">
                                    <Run Text="1. Tartım: "/><Run Text="{Binding Weight, Mode=OneWay}"/><Run Text=" kg"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </DockPanel>

        <!-- Kamera -->
        <DockPanel Grid.Column="1" Margin="0,0,20,0">
            <TextBlock DockPanel.Dock="Top" Text="Aracın çıkış tartısı — canlı kamera"
                       FontFamily="{StaticResource GoogleSansMedium}"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,14"/>
            <Border CornerRadius="16" ClipToBounds="True" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <views:CameraView/>
            </Border>
        </DockPanel>

        <!-- Form -->
        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="26">
            <StackPanel>
                <TextBlock Text="PLAKA" Style="{StaticResource DialogLabel}"/>
                <TextBlock Text="{Binding Selected.Plate}" FontSize="24" FontFamily="{StaticResource GoogleSansBold}" Margin="0,0,0,14"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="1. Tartım" Style="{StaticResource DialogLabel}"/>
                        <TextBlock FontSize="20" FontFamily="{StaticResource GoogleSansMedium}">
                            <Run Text="{Binding Selected.Weight, Mode=OneWay}"/><Run Text=" kg"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="2. Tartım (canlı)" Style="{StaticResource DialogLabel}"/>
                        <TextBlock FontSize="20" FontFamily="{StaticResource GoogleSansMedium}" Foreground="{DynamicResource SecondaryBrush}">
                            <Run Text="{Binding SecWeightValue, Mode=OneWay}"/><Run Text=" kg"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <CheckBox Content="Ağırlığı kantardan canlı al" IsChecked="{Binding LiveWeight}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding SecWeightValue, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding LiveWeight, Converter={x:Static views:NotConverter.Instance}}"
                         Margin="0,0,0,14"/>

                <Border Background="{DynamicResource SuccessSoftBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <TextBlock>
                        <Run Text="NET  " FontSize="15" Foreground="{DynamicResource SuccessBrush}"/>
                        <Run Text="{Binding Total, Mode=OneWay}" FontSize="30" FontFamily="{StaticResource GoogleSansBold}" Foreground="{DynamicResource SuccessBrush}"/>
                        <Run Text=" kg" FontSize="15" Foreground="{DynamicResource SuccessBrush}"/>
                    </TextBlock>
                </Border>

                <CheckBox Content="Kamyonet (Van)" IsChecked="{Binding IsVan}" Margin="0,4"/>
                <CheckBox Content="Ücret ödendi" IsChecked="{Binding IsPaid}" Margin="0,4"/>
                <CheckBox Content="Fiş yazdır" IsChecked="{Binding ShouldPrint}" Margin="0,4,0,18"/>

                <Button Content="Kaydet ve Bitir" Command="{Binding SaveCommand}" Height="50"
                        Style="{StaticResource PrimaryButton}" FontSize="16"/>
                <Button Content="Bekleyen Kaydı Sil" Command="{Binding DeleteCommand}" Height="42" Margin="0,10,0,0"
                        Style="{StaticResource DangerButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
