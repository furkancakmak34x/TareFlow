<UserControl x:Class="TareFlow.Center.Views.WeighStationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TareFlow.Center.Views">
    <UserControl.Resources>
        
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        
        <Style x:Key="CompactBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="CompactCheck" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>

        
        <Style x:Key="CameraTabList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,6,0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="12" Padding="11,6"
                                            Background="#66000000" BorderBrush="#33FFFFFF" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE412;" FontFamily="{DynamicResource GoogleMaterialSymbols}"
                                                       FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                       FontFamily="{StaticResource GoogleSansMedium}" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#99000000"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CamIconButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Padding="9,6"
                                Background="#66000000" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" FontFamily="{DynamicResource GoogleMaterialSymbols}"
                                           FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Content}" Foreground="White" Margin="5,0,0,0"
                                           FontFamily="{StaticResource GoogleSansMedium}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#99000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="RowItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="10,7">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="TextElement.Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" MinHeight="160"/>
            <RowDefinition Height="2*" MinHeight="240"/>
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" CornerRadius="14" ClipToBounds="True"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,12">
            <Grid>
                <views:CameraView/>
                <Grid VerticalAlignment="Top" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ListBox Grid.Column="0" Style="{StaticResource CameraTabList}"
                             ItemsSource="{Binding Cameras}"
                             SelectedIndex="{Binding SelectedCameraIndex, Mode=TwoWay}"/>
                    <Button Grid.Column="1" x:Name="BtnFullscreen" Style="{StaticResource CamIconButton}"
                            Tag="&#xE5D0;" Content="Tam Ekran" Click="BtnFullscreen_Click"/>
                </Grid>

                
                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"
                        CornerRadius="12" Padding="14,8" Background="#99000000">
                    <TextBlock Foreground="White" FontFamily="{StaticResource GoogleSansBold}">
                        <Run Text="{Binding Scale.CurrentWeight, Mode=OneWay}" FontSize="26"/>
                        <Run Text=" kg" FontSize="14"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

            <TabItem Header="1. Tartım">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CANLI AĞIRLIK" Style="{StaticResource FieldLabel}"/>
                            <Border Padding="16,12" CornerRadius="12" Background="{DynamicResource SurfaceVariantBrush}" Margin="0,0,0,12">
                                <TextBlock TextAlignment="Center" Foreground="{DynamicResource SecondaryBrush}" FontFamily="{StaticResource GoogleSansBold}">
                                    <Run Text="{Binding Scale.CurrentWeight, Mode=OneWay}" FontSize="34"/>
                                    <Run Text=" kg" FontSize="16"/>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="Tarih" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Weigh.Date}" IsReadOnly="True" Style="{StaticResource CompactBox}"/>
                        </StackPanel>

                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Plaka" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Weigh.Plate, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16" Height="38" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <CheckBox Content="Alıcı" IsChecked="{Binding Weigh.UseCustomer}" Style="{StaticResource CompactCheck}"/>
                                    <TextBox Text="{Binding Weigh.Customer}" IsEnabled="{Binding Weigh.UseCustomer}" Style="{StaticResource CompactBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <CheckBox Content="Satıcı" IsChecked="{Binding Weigh.UseVendor}" Style="{StaticResource CompactCheck}"/>
                                    <TextBox Text="{Binding Weigh.Vendor}" IsEnabled="{Binding Weigh.UseVendor}" Style="{StaticResource CompactBox}"/>
                                </StackPanel>
                            </Grid>
                            <CheckBox Content="Ürün" IsChecked="{Binding Weigh.UseProduct}" Style="{StaticResource CompactCheck}" Margin="0,8,0,3"/>
                            <TextBox Text="{Binding Weigh.Product}" IsEnabled="{Binding Weigh.UseProduct}" Style="{StaticResource CompactBox}"/>
                            <Button Content="Kaydet" Command="{Binding Weigh.SaveCommand}" Height="44" Margin="0,14,0,0"
                                    Style="{StaticResource PrimaryButton}" FontSize="15"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            
            <TabItem Header="2. Tartım">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    
                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top" Text="Bekleyen Araçlar" FontSize="13"
                                   FontFamily="{StaticResource GoogleSansBold}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="5">
                            <ListBox ItemsSource="{Binding Second.Pending}" SelectedItem="{Binding Second.Selected}"
                                     Background="Transparent" BorderThickness="0"
                                     ItemContainerStyle="{StaticResource RowItem}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Plate}" FontFamily="{StaticResource GoogleSansBold}" FontSize="14"/>
                                            <TextBlock Text="{Binding Date}" Opacity="0.7" FontSize="10"/>
                                            <TextBlock FontSize="10" Opacity="0.8">
                                                <Run Text="1. Tartım: "/><Run Text="{Binding Weight, Mode=OneWay}"/><Run Text=" kg"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </DockPanel>

                    
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PLAKA" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding Second.Selected.Plate}" FontSize="22" FontFamily="{StaticResource GoogleSansBold}" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="1. Tartım" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock FontSize="16" FontFamily="{StaticResource GoogleSansMedium}">
                                            <Run Text="{Binding Second.Selected.Weight, Mode=OneWay}"/><Run Text=" kg"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="2. Tartım (canlı)" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock FontSize="16" FontFamily="{StaticResource GoogleSansMedium}" Foreground="{DynamicResource SecondaryBrush}">
                                            <Run Text="{Binding Second.SecWeightValue, Mode=OneWay}"/><Run Text=" kg"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <CheckBox Content="Ağırlığı kantardan canlı al" IsChecked="{Binding Second.LiveWeight}" Style="{StaticResource CompactCheck}"/>
                                <TextBox Text="{Binding Second.SecWeightValue, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding Second.LiveWeight, Converter={x:Static views:NotConverter.Instance}}"
                                         Style="{StaticResource CompactBox}"/>
                                <Border Background="{DynamicResource SuccessSoftBrush}" CornerRadius="10" Padding="12" Margin="0,10,0,0">
                                    <TextBlock>
                                        <Run Text="NET  " FontSize="13" Foreground="{DynamicResource SuccessBrush}"/>
                                        <Run Text="{Binding Second.Total, Mode=OneWay}" FontSize="24" FontFamily="{StaticResource GoogleSansBold}" Foreground="{DynamicResource SuccessBrush}"/>
                                        <Run Text=" kg" FontSize="13" Foreground="{DynamicResource SuccessBrush}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Seçenekler" Style="{StaticResource FieldLabel}"/>
                                <CheckBox Content="Kamyonet (Van)" IsChecked="{Binding Second.IsVan}" Style="{StaticResource CompactCheck}"/>
                                <CheckBox Content="Ücret ödendi" IsChecked="{Binding Second.IsPaid}" Style="{StaticResource CompactCheck}"/>
                                <CheckBox Content="Fiş yazdır" IsChecked="{Binding Second.ShouldPrint}" Style="{StaticResource CompactCheck}"/>
                                <Button Content="Kaydet ve Bitir" Command="{Binding Second.SaveCommand}" Height="44" Margin="0,12,0,0"
                                        Style="{StaticResource PrimaryButton}" FontSize="15"/>
                                <Button Content="Bekleyen Kaydı Sil" Command="{Binding Second.DeleteCommand}" Height="38" Margin="0,8,0,0"
                                        Style="{StaticResource DangerButton}" FontSize="13"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            
            <TabItem Header="Sabit Dara">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    
                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top" Text="Kayıtlı Daralar" FontSize="13"
                                   FontFamily="{StaticResource GoogleSansBold}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="5">
                            <ListBox ItemsSource="{Binding Tare.KnownPlates}" SelectedItem="{Binding Tare.SelectedKnown, Mode=TwoWay}"
                                     Background="Transparent" BorderThickness="0"
                                     ItemContainerStyle="{StaticResource RowItem}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Plate}" FontFamily="{StaticResource GoogleSansBold}" FontSize="14"/>
                                            <TextBlock FontSize="10" Opacity="0.8">
                                                <Run Text="Dara: "/><Run Text="{Binding Weight, Mode=OneWay}"/><Run Text=" kg"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </DockPanel>

                    
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Plaka" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Tare.Plate, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="16" Height="38" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Kayıtlı Dara" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="{Binding Tare.TareDisplay}" FontSize="16" FontFamily="{StaticResource GoogleSansMedium}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Dolu (canlı)" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock FontSize="16" FontFamily="{StaticResource GoogleSansMedium}" Foreground="{DynamicResource SecondaryBrush}">
                                            <Run Text="{Binding Tare.LoadedValue, Mode=OneWay}"/><Run Text=" kg"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <CheckBox Content="Dolu ağırlığı canlı al" IsChecked="{Binding Tare.LiveWeight}" Style="{StaticResource CompactCheck}"/>
                                <TextBox Text="{Binding Tare.LoadedValue, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding Tare.LiveWeight, Converter={x:Static views:NotConverter.Instance}}"
                                         Style="{StaticResource CompactBox}"/>
                                <Border Background="{DynamicResource SuccessSoftBrush}" CornerRadius="10" Padding="12" Margin="0,10,0,0">
                                    <TextBlock>
                                        <Run Text="NET  " FontSize="13" Foreground="{DynamicResource SuccessBrush}"/>
                                        <Run Text="{Binding Tare.Net, Mode=OneWay}" FontSize="24" FontFamily="{StaticResource GoogleSansBold}" Foreground="{DynamicResource SuccessBrush}"/>
                                        <Run Text=" kg" FontSize="13" Foreground="{DynamicResource SuccessBrush}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <CheckBox Content="Alıcı" IsChecked="{Binding Tare.UseCustomer}" Style="{StaticResource CompactCheck}"/>
                                        <TextBox Text="{Binding Tare.Customer}" IsEnabled="{Binding Tare.UseCustomer}" Style="{StaticResource CompactBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <CheckBox Content="Ürün" IsChecked="{Binding Tare.UseProduct}" Style="{StaticResource CompactCheck}"/>
                                        <TextBox Text="{Binding Tare.Product}" IsEnabled="{Binding Tare.UseProduct}" Style="{StaticResource CompactBox}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <CheckBox Content="Van" IsChecked="{Binding Tare.IsVan}" Style="{StaticResource CompactCheck}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Ödendi" IsChecked="{Binding Tare.IsPaid}" Style="{StaticResource CompactCheck}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Fiş" IsChecked="{Binding Tare.ShouldPrint}" Style="{StaticResource CompactCheck}"/>
                                </StackPanel>
                                <Button Content="Darayı Kaydet (boş)" Command="{Binding Tare.SaveTareCommand}" Height="40"
                                        Style="{StaticResource SecondaryButton}" FontSize="13"/>
                                <Button Content="Tartım + Fiş Bas" Command="{Binding Tare.WeighCommand}" Height="44" Margin="0,8,0,0"
                                        Style="{StaticResource PrimaryButton}" FontSize="15"/>
                                <Button Content="Darayı Sil" Command="{Binding Tare.DeleteTareCommand}" Height="34" Margin="0,6,0,0"
                                        Style="{StaticResource GhostButton}" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
