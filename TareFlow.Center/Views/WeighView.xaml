<UserControl x:Class="TareFlow.Center.Views.WeighView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TareFlow.Center.Views">
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Kamera -->
        <DockPanel Grid.Column="0" Margin="0,0,24,0">
            <TextBlock DockPanel.Dock="Top" Text="Aracın giriş tartısı — canlı kamera"
                       FontFamily="{StaticResource GoogleSansMedium}"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,14"/>
            <Border CornerRadius="16" ClipToBounds="True" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <views:CameraView/>
            </Border>
        </DockPanel>

        <!-- Form -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="26">
            <StackPanel>
                <TextBlock Text="CANLI AĞIRLIK" FontSize="12" FontFamily="{StaticResource GoogleSansMedium}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Border Margin="0,8,0,20" Padding="20,14" CornerRadius="14" Background="{DynamicResource SurfaceVariantBrush}">
                    <TextBlock TextAlignment="Center" Foreground="{DynamicResource SecondaryBrush}" FontFamily="{StaticResource GoogleSansBold}">
                        <Run Text="{Binding Scale.CurrentWeight, Mode=OneWay}" FontSize="48"/>
                        <Run Text=" kg" FontSize="22"/>
                    </TextBlock>
                </Border>

                <TextBlock Text="Tarih" Style="{StaticResource DialogLabel}"/>
                <TextBox Text="{Binding Date}" IsReadOnly="True" Margin="0,0,0,14"/>

                <TextBlock Text="Plaka" Style="{StaticResource DialogLabel}"/>
                <TextBox Text="{Binding Plate, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Margin="0,0,0,16"/>

                <CheckBox Content="Alıcı" IsChecked="{Binding UseCustomer}" Margin="0,4"/>
                <TextBox Text="{Binding Customer}" IsEnabled="{Binding UseCustomer}" Margin="0,4,0,10"/>

                <CheckBox Content="Satıcı" IsChecked="{Binding UseVendor}" Margin="0,4"/>
                <TextBox Text="{Binding Vendor}" IsEnabled="{Binding UseVendor}" Margin="0,4,0,10"/>

                <CheckBox Content="Ürün" IsChecked="{Binding UseProduct}" Margin="0,4"/>
                <TextBox Text="{Binding Product}" IsEnabled="{Binding UseProduct}" Margin="0,4,0,20"/>

                <Button Content="Kaydet" Command="{Binding SaveCommand}" Height="50"
                        Style="{StaticResource PrimaryButton}" FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
