<UserControl x:Class="TareFlow.Center.Views.RecordsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="28">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Tartım Kayıtları" FontSize="26"
                       FontFamily="{StaticResource GoogleSansBold}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Plaka veya tarih ile filtrele"/>
            <Button Grid.Column="2" Content="Sil" Command="{Binding DeleteCommand}" Margin="12,0,0,0"
                    Width="90" Style="{StaticResource DangerButton}"/>
        </Grid>

        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="14"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="2">
            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0"
                      Background="Transparent" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" RowHeight="36" FontSize="14">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Plaka" Binding="{Binding Plate}" Width="120"/>
                    <DataGridTextColumn Header="Giriş" Binding="{Binding Date}" Width="150"/>
                    <DataGridTextColumn Header="Çıkış" Binding="{Binding SecDate}" Width="150"/>
                    <DataGridTextColumn Header="Alıcı" Binding="{Binding Customer}" Width="*"/>
                    <DataGridTextColumn Header="Satıcı" Binding="{Binding Vendor}" Width="*"/>
                    <DataGridTextColumn Header="Ürün" Binding="{Binding Product}" Width="*"/>
                    <DataGridTextColumn Header="1.Tartım" Binding="{Binding Weight}" Width="90"/>
                    <DataGridTextColumn Header="2.Tartım" Binding="{Binding SecWeight}" Width="90"/>
                    <DataGridTextColumn Header="Net" Binding="{Binding Total}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
