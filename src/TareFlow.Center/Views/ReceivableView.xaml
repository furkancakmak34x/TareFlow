<UserControl x:Class="TareFlow.Center.Views.ReceivableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="28">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Tahsilat" FontSize="26"
                       FontFamily="{StaticResource GoogleSansBold}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Tahsil Et" Command="{Binding CollectCommand}"
                    Width="130" Style="{StaticResource PrimaryButton}"/>
        </Grid>

        <Border DockPanel.Dock="Bottom" Background="{DynamicResource WarningSoftBrush}" CornerRadius="12"
                Padding="18" Margin="0,16,0,0">
            <TextBlock>
                <Run Text="Toplam Bekleyen Tahsilat:  " FontSize="15" Foreground="{DynamicResource WarningBrush}"/>
                <Run Text="{Binding TotalFee, Mode=OneWay}" FontSize="22" FontFamily="{StaticResource GoogleSansBold}" Foreground="{DynamicResource WarningBrush}"/>
                <Run Text=" ₺" FontSize="15" Foreground="{DynamicResource WarningBrush}"/>
            </TextBlock>
        </Border>

        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="14"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="2">
            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0"
                      Background="Transparent" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" RowHeight="36" FontSize="14">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Plaka" Binding="{Binding Plate}" Width="180"/>
                    <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="220"/>
                    <DataGridTextColumn Header="Ücret (₺)" Binding="{Binding Fee}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
